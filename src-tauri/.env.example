# Existing (already used by the agent backend)
GEMINI_API_KEY=

# Google Cloud Speech-to-Text (service account JSON key path)
# You said your key file is named keys.json.
# If keys.json is in src-tauri/, use: keys.json
# If keys.json is in repo root, use: ../keys.json
GCP_SERVICE_ACCOUNT_KEY_PATH=keys.json

# Optional STT tuning
GCP_STT_LANGUAGE_CODE=en-US
GCP_STT_MODEL=latest_short
