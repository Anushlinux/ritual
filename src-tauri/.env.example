# Claude agent backend
ANTHROPIC_API_KEY=
# Optional. Defaults to Claude Sonnet 4.5.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Optional. Defaults to 2023-06-01.
ANTHROPIC_VERSION=2023-06-01

# Connectors use env tokens for now. The in-app OAuth callback flow is not wired yet.
# GitHub fine-grained/classic token with repository, issue, and pull-request access.
GITHUB_TOKEN=
# Google OAuth access token with Gmail and Calendar scopes.
GOOGLE_ACCESS_TOKEN=

# Google Cloud Speech-to-Text (service account JSON key path)
# You said your key file is named keys.json.
# If keys.json is in src-tauri/, use: keys.json
# If keys.json is in repo root, use: ../keys.json
GCP_SERVICE_ACCOUNT_KEY_PATH=keys.json

# Optional STT tuning
GCP_STT_LANGUAGE_CODE=en-US
GCP_STT_MODEL=latest_short
